# Copy this file to .env and fill in your own token.
# Get a token at https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Optional: which hosted chat model the AI Chat Assistant uses.
# Defaults to HuggingFaceH4/zephyr-7b-beta if unset.
SUCAS_LLM_REPO_ID=HuggingFaceH4/zephyr-7b-beta
